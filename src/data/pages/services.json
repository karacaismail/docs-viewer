    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Dış servisler katmanı: e-posta gönderimi, SMS, ödeme, harita, hava durumu gibi 3. parti hizmetlerin sisteme bağlanma noktaları."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Her ürün e-posta sunucusunu sıfırdan kurmaz. SendGrid gibi hazır hizmetler kullanılır. Bu katman bağlantıları yönetir."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "Sistemde 'e-posta gönder' denildiğinde bu katman gerçek e-posta sağlayıcısına çevirir."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Sistemin dış dünyaya açılan kapısı."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Her dış hizmet çağrısında."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Geliştirici 'gönder' der; sistem dış sağlayıcıyı çağırır; son kullanıcı e-postayı alır."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Bir oteldeki resepsiyon: misafir 'taksi çağırın' der, resepsiyon dış taksi şirketini arar. Misafir taksi şirketini bilmez."
       }
      ]
     }
    ]
