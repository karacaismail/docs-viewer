    "id": "block-fe-core-ui-lesson-2",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Tüm ürünlerin paylaştığı temel arayüz parçaları: butonlar, formlar, tablolar, menüler. Bir kez yazılır, 15 üründe kullanılır."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Her ürünün kendi butonu olsaydı ölçü farklı, renk farklı, davranış farklı olur — kullanıcı kafası karışırdı. Ortak parçalar tutarlılık verir."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "Tasarımcı tasarlar, geliştirici parçaları kodlar, paylaşılan klasöre koyar. Her ürün ister."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Paylaşılan klasördeki 'core-ui' kütüphanesi."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Tüm ürünlerin yapımında — her form, her tablo, her buton bu kütüphaneden gelir."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Tasarım sistemi mimarı yönetir; tüm ürün ekipleri kullanır."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "IKEA mobilyalarındaki standart vidalar ve menteşeler: hangi mobilyaya bakarsan bak aynı vidalar kullanılır. Standart = kalite + hız."
       }
      ]
     }
    ]
