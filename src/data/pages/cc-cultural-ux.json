   {
    "id": "block-cc-cultural-ux-h-yedi-soruda",
    "type": "heading",
    "level": 2,
    "text": "Bu konu yedi soruda"
   },
   {
    "id": "block-cc-cultural-ux-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "i18n'in kültür + a11y boyutu: renk anlamı, jest, font fallback, RTL ikon yönü, screen reader lang attribute."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Teknik standart (BCP 47, ICU) yetmez — kültürel/algısal anlam ayrı. Yanlış renk = yanlış mesaj; yanlış font = okunamayan içerik; yanlış lang = yanlış telaffuz."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) Cultural theme variant per jurisdiction. 2) Mesaj icon+text+renk üçü birlikte. 3) Font stack + unicode-range + lazy load. 4) CSS logical properties RTL. 5) "
       },
       {
        "type": "code",
        "text": "<html lang>"
       },
       {
        "type": "text",
        "text": " dinamik + inline lang çoklu dil."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "cc-cultural-ux"
       },
       {
        "type": "text",
        "text": " cluster + "
       },
       {
        "type": "code",
        "text": "cc-i18n-standards"
       },
       {
        "type": "text",
        "text": " (teknik) + "
       },
       {
        "type": "code",
        "text": "cc-a11y-backend"
       },
       {
        "type": "text",
        "text": " (EAA). Frontend bileşen kütüphanesinde uygulanır."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk ek dil/kültür eklenmeden ÖNCE font + lang disiplini. Cultural theme ek pazar açılımında."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Designer kültürel renk + manken; frontend dev font stack + lang attribute; a11y consultant denetim."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Yemek davetinde misafire göre menü: vejetaryen, alerjisi var, dini kısıt. Aynı yemeği herkese koymak ayıp. Yazılım UI = misafir davası: herkese 'aynı menü' kültürel saldırı; yerel adaptasyon = saygı."
       }
      ]
     }
    ]
   },
   {
    "id": "block-cc-cultural-ux-h-hikayeler",
    "type": "heading",
    "level": 2,
    "text": "Kullanım hikâyeleri"
   },
   {
    "id": "block-cc-cultural-ux-story",
    "type": "useCase",
    "title": "Ürün tasarımcı Selin Hanım (38) — CN açılım",
    "scenario": [
     {
      "type": "text",
      "text": "Tasarım sisteminde 'success = yeşil', 'error = kırmızı'. CN pazara açıldığında 'yeni yıl indirim' banner'ı yeşil yaptılar — yerel ekip 'kırmızı olsa daha uğurlu' dedi."
     }
    ],
    "outcome": [
     {
      "type": "text",
      "text": "Tema sistemine "
     },
     {
      "type": "strong",
      "text": "cultural variant"
     },
     {
      "type": "text",
      "text": " eklendi: jurisdiction CN ise primary accent = kırmızı (uğur). Mesaj iletme "
     },
     {
      "type": "strong",
      "text": "icon + metin + renk"
     },
     {
      "type": "text",
      "text": " üçü birlikte (a11y + kültürel)."
     }
    ]
   },
   {
    "id": "block-cc-cultural-ux-story-2",
    "type": "useCase",
    "title": "Geliştirici Murat Bey (61'lik abisi 30) — font fallback",
    "scenario": [
     {
      "type": "text",
      "text": "Web sitesi Türkçe + İngilizce yayında. Hindistan kullanıcı 'टेस्ट' (Devanagari) yorum yazdı; sayfada kutu karakterler (Tofu) görünüyor."
     }
    ],
    "outcome": [
     {
      "type": "text",
      "text": "Font stack güncellendi: Inter + Noto Sans Devanagari + Noto Sans CJK lazy load. unicode-range ile sadece gerekli karakter setleri yüklenir. Tofu sorunu çözüldü."
     }
    ]
   },
   {
    "id": "block-cc-cultural-ux-story-3",
    "type": "useCase",
    "title": "A11y consultant Ayşe Hanım (50) — screen reader",
    "scenario": [
     {
      "type": "text",
      "text": "WCAG audit: site "
     },
     {
      "type": "code",
      "text": "<html lang='en'>"
     },
     {
      "type": "text",
      "text": " ama Türkçe içerik. Screen reader 'Merhaba'yı 'mer-haba' diye telaffuz ediyor."
     }
    ],
    "outcome": [
     {
      "type": "code",
      "text": "<html lang='tr'>"
     },
     {
      "type": "text",
      "text": " set + dinamik dil değişiminde JS update + farklı dilli içerik için inline "
     },
     {
      "type": "code",
      "text": "lang"
     },
     {
      "type": "text",
      "text": " attribute. WCAG 3.1.1 (A) compliance."
     }
    ]
   }
  ]
 }
