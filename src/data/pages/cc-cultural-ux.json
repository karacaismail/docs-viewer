   {
    "id": "block-cc-cultural-ux-h-5",
    "type": "heading",
    "level": 2,
    "text": "5. Ekran Okuyucu `lang` Attribute"
   },
   {
    "id": "block-cc-cultural-ux-p-11",
    "type": "paragraph",
    "segments": [
     {
      "type": "text",
      "text": "Screen reader (NVDA, JAWS, VoiceOver) telaffuz için sayfanın "
     },
     {
      "type": "strong",
      "text": "gerçek dilini"
     },
     {
      "type": "text",
      "text": " bilir."
     }
    ]
   },
   {
    "id": "block-cc-cultural-ux-p-12",
    "type": "paragraph",
    "segments": [
     {
      "type": "strong",
      "text": "Yanlış:"
     }
    ]
   },
   {
    "id": "block-cc-cultural-ux-code-3",
    "type": "codeBlock",
    "language": "html",
    "code": "<html lang='en'>\n<body>\n  <p>Merhaba dünya</p>  <!-- screen reader Türkçe'yi İngilizce telaffuz eder -->\n</body>"
   },
   {
    "id": "block-cc-cultural-ux-p-13",
    "type": "paragraph",
    "segments": [
     {
      "type": "strong",
      "text": "Doğru:"
     }
    ]
   },
   {
    "id": "block-cc-cultural-ux-code-4",
    "type": "codeBlock",
    "language": "html",
    "code": "<html lang='tr'>\n<body>\n  <p>Merhaba dünya</p>\n  <p lang='en'>Hello world</p>  <!-- karışık dilli içerik için -->\n</body>"
   },
   {
    "id": "block-cc-cultural-ux-p-14",
    "type": "paragraph",
    "segments": [
     {
      "type": "strong",
      "text": "Disiplin:"
     },
     {
      "type": "text",
      "text": " her sayfada "
     },
     {
      "type": "code",
      "text": "<html lang>"
     },
     {
      "type": "text",
      "text": " doğru set + farklı dilli içerik için "
     },
     {
      "type": "code",
      "text": "lang"
     },
     {
      "type": "text",
      "text": " attribute. WCAG 3.1.1 (A) + 3.1.2 (AA) zorunlu."
     }
    ]
   },
