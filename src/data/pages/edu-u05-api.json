   {
    "id": "block-edu-u05-api-urs-code",
    "type": "codeBlock",
    "title": "ECA kuralı — API: REST ve GraphQL — pratik anlatım",
    "language": "yaml",
    "code": "trigger:\n  event: http.post\n  path: /api/orders\ncondition:\n  all:\n    - request.has_idempotency_key\n    - not seen(request.idempotency_key)\n    - actor.capability >= \"order.create\"\naction:\n  - emit: order.created\n  - respond: 201 Created\nguards:\n  max_depth: 6\n  idempotency_key: \"{request.idempotency_key}\"\n  external_effects: step_up_required",
    "copyEnabled": true
   },
