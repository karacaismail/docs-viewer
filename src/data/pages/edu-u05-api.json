    "text": "1. Özellik tanımları"
   },
   {
    "id": "block-edu-u05-api-urs-dl",
    "type": "definitionList",
    "items": [
     {
      "term": "Method-eylem eşlemesi",
      "definition": [
       {
        "type": "strong",
        "text": "Kritik. "
       },
       {
        "type": "text",
        "text": "GET oku / POST oluştur / PUT tam değiştir / PATCH kısmi / DELETE sil — URL kaynağı, method eylemi taşır; doğru method doğru cache, retry ve log davranışını belirler."
       }
      ]
     },
     {
      "term": "Idempotency-Key ile güvenli retry",
      "definition": [
       {
        "type": "strong",
        "text": "Kritik. "
       },
       {
        "type": "text",
        "text": "POST tabiatı gereği idempotent değildir; istemci ürettiği unique key ile aynı isteği tekrarlasa da sunucu ikinciyi yutar — ağ koparsa kart bir kez çekilir."
       }
      ]
     },
     {
      "term": "Status-code sözleşmesi",
      "definition": [
       {
        "type": "strong",
        "text": "Kritik. "
       },
       {
        "type": "text",
        "text": "200/201/204/400/401/403/404/409/422/429/500 — frontend hangi UX'i göstereceğini (düzelt, giriş yap, yetki yok, merge ekranı, bekle) status'a göre seçer."
       }
      ]
     },
     {
      "term": "REST + GraphQL ikiz üretimi",
      "definition": [
       {
        "type": "text",
        "text": "ArcheType tanımlandığında framework hem REST hem GraphQL ucunu otomatik üretir; istemci kullanım pattern'ine göre seçer, geliştirici seçmez."
       }
      ]
     }
    ]
   },
