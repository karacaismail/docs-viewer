   {
    "id": "block-edu-u05-api-steps",
    "type": "stepList",
    "steps": [
     {
      "title": "Mobil app POST atıyor",
      "segments": [
       {
        "type": "text",
        "text": "Kullanıcı 'Öde' butonuna basar. Frontend "
       },
       {
        "type": "code",
        "text": "Idempotency-Key: ABC-123"
       },
       {
        "type": "text",
        "text": " header'ı ile POST /payments."
       }
      ]
     },
     {
      "title": "Ağ koptu",
      "segments": [
       {
        "type": "text",
        "text": "App cevap alamadı. Otomatik retry: aynı body, aynı key ile tekrar POST."
       }
      ]
     },
     {
      "title": "Sunucu key'i tanır",
      "segments": [
       {
        "type": "text",
        "text": "Daha önce ABC-123 ile çekilmişti; tekrar çekmez. İlk istekteki cevabı "
       },
       {
        "type": "strong",
        "text": "aynen"
       },
       {
        "type": "text",
        "text": " döner."
       }
      ]
     },
     {
      "title": "Müşteri tek çekildi",
      "segments": [
       {
        "type": "text",
        "text": "İki retry, tek transaction. Kart şirketinden olumlu cevap, kullanıcıdan tek tahsilat."
       }
      ]
     }
    ]
   },
