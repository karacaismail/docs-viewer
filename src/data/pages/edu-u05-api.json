     {
      "term": "Kod optimizasyonu",
      "definition": [
       {
        "type": "text",
        "text": "Tip-güvenli sınırlar, ölü kod yok, saf fonksiyon + Strategy; "
       },
       {
        "type": "code",
        "text": "if (type==...)"
       },
       {
        "type": "text",
        "text": " yasak — runtime dispatch."
       }
      ]
     },
     {
      "term": "Güvenlik optimizasyonu",
      "definition": [
       {
        "type": "text",
        "text": "Deny-by-default, sır sızıntısı taraması, bağımlılık denetimi CI kapısı."
       }
      ]
     },
     {
      "term": "Performans optimizasyonu",
      "definition": [
       {
        "type": "text",
        "text": "Keyset (cursor) pagination — OFFSET yok; N+1 yok; "
       },
       {
        "type": "code",
        "text": "async def"
       },
       {
        "type": "text",
        "text": " içinde bloklama yok; p95 SLO bütçesi; gerekli indeks."
       }
      ]
     },
     {
      "term": "Yük profili",
      "definition": [
       {
        "type": "text",
        "text": "Yüksek-hacimli ArcheType opt-in fiziksel tabloya terfi; aksi halde hibrit şema."
       }
      ]
     }
