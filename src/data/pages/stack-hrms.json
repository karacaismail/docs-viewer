     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "İnsan kaynakları modülü: personel kayıtları, izin, bordro, performans, eğitim, terfi — çalışanlarla ilgili tüm yönetim tek yerden."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Personel sayısı arttıkça Excel'de takip yetmez. Yasal yükümlülükler (SGK bildirgesi, KVKK) tek sistemde tutulmalı."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "Personel sisteme kaydedilir → izin talebi açar → yöneticisi onaylar → bordro otomatik hesaplanır → SGK bildirimi otomatik gönderilir."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Her şirketin İK departmanının yönettiği veriler — kayıtlar, talepler, raporlar."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Yeni personel girişi, izin talebi, ay sonu bordro, yıl sonu performans değerlendirmesi."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "İK uzmanı kayıtları tutar; yönetici onaylar; çalışan kendi bilgisini görür; SGK e-bildirim üzerinden okur."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
