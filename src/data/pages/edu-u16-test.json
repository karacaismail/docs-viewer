    "id": "block-edu-u16-test-p-8",
    "type": "paragraph",
    "segments": [
     {
      "type": "strong",
      "text": "Integration test = parça birleşim"
     },
     {
      "type": "text",
      "text": ": Gerçek DB (test database), gerçek HTTP server. Saniye seviyesi."
     }
    ]
