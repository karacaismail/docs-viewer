   {
    "id": "block-edu-u16-test-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Yazılımın doğru çalıştığını kanıtlayan otomatik kontrol mekanizması. 3 katman: küçük birim (unit) → birleşim (integration) → kullanıcı yolu (e2e)."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Test yoksa her değişiklik 'çalışıyor mu?' belirsizliği. Test varsa 5 saniyede 1000 senaryo kontrol edilir."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) Her yeni fonksiyon için unit test. 2) Kritik API endpoint'i için integration test. 3) Happy path için e2e. 4) Coverage hedefini CI'da zorla."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Vitest (unit + integration), Playwright (e2e). CI'da her PR'da çalışır."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Test ÖNCE yaz (TDD) veya kodla birlikte. Sonradan yazılan test = yazılmıyor."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Geliştirici kendi testini yazar; tech lead coverage hedefini koyar; CI zorlar."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Restoran: aşçı malzemeyi tek tek kontrol eder (unit), yemeği tabakta tadar (integration), garson servis öncesi son bakar (e2e)."
       }
      ]
     }
    ]
   },
