    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "En yaygın 10 web saldırısı; nasıl yapılır, nasıl korunur."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Bir bug = bir özellik kaybı. Bir güvenlik açığı = tüm veri tabanı sızıntısı + iş kaybı."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) Prepared statement (SQL injection). 2) Framework auto-escape (XSS). 3) SameSite cookie + CSRF token. 4) Her endpoint yetki kontrolü (IDOR). 5) bcrypt/argon2 parola. 6) Dependabot. 7) Rate limit."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "cc-security"
       },
       {
        "type": "text",
        "text": " cluster + her DocType handler'da yetki kontrolü. CI'da Snyk/Trivy tarama."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk satır kod yazılırken. Sonradan eklemek imkânsız."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Tüm geliştiriciler bilir; security champion kontrol eder; pentester yılda 1 doğrular."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Apartman güvenlik: kapı kilidi (auth), interkom (validation), kamera (logging), bekçi (rate limit), site sözleşmesi (yetki). Hepsi olunca güvenli."
       }
      ]
     }
