    "id": "block-s-payment-methods-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Ülke başına yerel ödeme yöntemleri matrisi + PSD2 SCA + TR taksit + gateway seçimi."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "'Kredi kartı yeter' yanılgısı = ülke başına %30-60 dönüşüm kaybı. Müşteri Pix istiyor, sen kart sunuyorsun = kayıp."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) Resolver jurisdiction'a göre payment_methods capability. 2) Gateway: TR Iyzico, AB Stripe, BR MercadoPago, IN Razorpay. 3) PSD2 SCA AB'de zorunlu. 4) TR taksit UI zorunlu, AB'de yok."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "s-payment-methods"
       },
       {
        "type": "text",
        "text": " cluster + "
       },
       {
        "type": "code",
        "text": "s-billing"
       },
       {
        "type": "text",
        "text": " (recurring) + "
       },
       {
        "type": "code",
        "text": "cc-jurisdiction-resolver"
       },
       {
        "type": "text",
        "text": " (locale'e değil jurisdiction'a bağla)."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk ödeme alınmadan ÖNCE pazar bazlı stratejisi netleşmeli."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Backend dev gateway entegre; finance team komisyon hesabı; ürün ekibi pazar başına UI."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Yurt dışı seyahatte cüzdan: TR'de kart + nakit, Avrupa'da SEPA + kart, Japonya'da nakit + Suica kartı. Tek tip cüzdan = ya kabul edilmez ya pahalı. Yerelleştir."
       }
      ]
     }
    ]
