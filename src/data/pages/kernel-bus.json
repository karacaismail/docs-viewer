   },
   {
    "id": "block-kernel-bus-p-10",
    "type": "paragraph",
    "segments": [
     {
      "type": "text",
      "text": "Module'lerin loose-coupled konuştuğu omurga. Aynı kod, üç ölçek."
     }
    ]
   },
   {
    "id": "block-kernel-bus-h-yedi-soruda",
    "type": "heading",
    "level": 2,
    "text": "Bu konu yedi soruda"
   },
   {
    "id": "block-kernel-bus-lesson-2",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Bir modülün 'şu oldu' duyurusunu diğer modüllerin duyabilmesi için kurulan iç anons sistemi. Mesajları taşıyan bir hat."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Modüller birbirini doğrudan çağırırsa hepsi birbirine bağımlı hale gelir. Anons sistemi sayesinde bağımsız kalır, sadece duydukları zaman tepki verirler."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "Sipariş modülü 'sipariş açıldı' diye anons yayınlar → muhasebe modülü duyar, fatura üretir → kargo modülü duyar, gönderi açar → stok modülü duyar, ürünü düşer. Her biri kendi başına."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Sistemin arka planında çalışır; kullanıcı görmez ama olayların zincirleme tetiklenmesi bu sayede olur."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Bir modülde önemli bir şey olduğunda (sipariş, ödeme, iptal, onay)."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Geliştirici 'duyacak modülleri' kaydeder; sistem mesajı taşır; son kullanıcı her şeyin otomatik aktığını görür."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Bir okuldaki anons hoparlörü: 'son ders bitti' anonsu çıkar; öğretmen sınıfı toplar, müdür kapıyı açar, servis şoförü motoru çalıştırır. Hiçbiri diğerini aramadı — anonsu duydu."
       }
      ]
     }
    ]
   },
   {
    "id": "block-kernel-bus-h-hikayeler",
    "type": "heading",
    "level": 2,
    "text": "Kullanım hikâyeleri"
   },
   {
    "id": "block-kernel-bus-story",
    "type": "useCase",
    "title": "Çiçekçi dükkânı sahibi Selma Hanım",
    "scenario": [
     {
      "type": "text",
      "text": "Internet siparişi alıyor. Sipariş gelince üç şey olmalı: muhasebede fatura kesilmeli, atölyede buket hazırlanmalı, kargo şirketine teslim notu gitmeli. Şu an tek tek hatırlamak zorunda."
     }
    ],
    "outcome": [
     {
      "type": "text",
      "text": "Sistemde sipariş alındığı an 'Yeni Sipariş' diye duyuru çıkar. Üç ayrı modül — muhasebe, üretim, kargo — duyuruyu duyup kendi işini başlatır. Selma Hanım tek tek 'haberin oldu mu' diye dolaşmaz."
     }
    ]
   },
   {
    "id": "block-kernel-bus-story-2",
    "type": "useCase",
    "title": "Camide müezzin",
    "scenario": [
     {
      "type": "text",
      "text": "Hoparlörden 'iftar 5 dakika sonra' anonsu yapılır. Cemaat duyar (oturur), aşçı duyar (yemekleri çıkarır), gönüllüler duyar (su dağıtmaya başlar). Müezzin kişiye tek tek söylemez."
     }
    ],
    "outcome": [
     {
      "type": "text",
      "text": "Yazılımdaki olay yayını da tam böyle: bir modül 'X oldu' der; ilgilenenler kendi tepkilerini verir. Mesajı taşıyan görünmez ama herkese ulaştıran sistem."
     }
    ]
   },
   {
    "id": "block-kernel-bus-story-3",
    "type": "useCase",
    "title": "Düğün organizatörü Mahmut Bey",
    "scenario": [
     {
      "type": "text",
      "text": "Gelin damat 'fotoğrafları çekildi' deyince: orkestra, ikinci dans için hazırlanır; aşçı, ana yemek servisine başlar; oyun ekibi, çocuk masasını harekete geçirir."
     }
    ],
    "outcome": [
     {
      "type": "text",
      "text": "Mahmut Bey herkese 'şimdi sıra sizde' diye gezmiyor — tek bir duyuru, çoklu otomatik tepki. Yazılımda da modüller bağımsız ama uyumlu — anons sayesinde."
     }
    ]
   }
  ]
 }
