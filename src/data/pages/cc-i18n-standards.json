   {
    "id": "block-cc-i18n-standards-h-yedi-soruda",
    "type": "heading",
    "level": 2,
    "text": "Bu konu yedi soruda"
   },
   {
    "id": "block-cc-i18n-standards-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Uluslararası dil/yerel desteğin teknik standartları — BCP 47 kodlama, CLDR veri, ICU pluralization, RTL bidi, locale-aware operations."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "'Çeviri' = i18n'in %20'si. Geri kalan %80: pluralization, format, RTL, collation, normalization. Bunlar olmadan 'çevrildi' yanılsama."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) i18next + i18next-icu library. 2) Intl API her yerde (tarih/sayı/para). 3) Tolgee TMS self-host. 4) CSS logical properties zorunlu. 5) Pseudo-localization CI test. 6) Locale-aware case + collation."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "cc-i18n-standards"
       },
       {
        "type": "text",
        "text": " cluster + "
       },
       {
        "type": "code",
        "text": "l1-misc"
       },
       {
        "type": "text",
        "text": " i18n temel + "
       },
       {
        "type": "code",
        "text": "cc-jurisdiction-resolver"
       },
       {
        "type": "text",
        "text": " locale eksen."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk ek dil eklenmeden ÖNCE. Sonradan refactor = tüm string'leri sarmak."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Frontend dev i18next + Intl; çevirmen TMS'de; QA pseudo-localization."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Yemek tarifi çevirisi: malzeme adlarını çevirmek yetmez; ölçü birimi (cup → ml), pişirme zamanı (180°F → 82°C), gramer (1 yumurta, 2 yumurta) hepsi yerelleşir. 'Tek tek değil topyekûn'."
       }
      ]
     }
    ]
   },
