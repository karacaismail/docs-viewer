   {
    "id": "block-cc-identity-models-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Global SaaS için kimlik veri modelleri — isim, adres, telefon, vergi numarası, cinsiyet. ABD-merkezli varsayımları kırma."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "firstName/lastName, '10 hane telefon', 'state zorunlu' = 2. ülkede çöker. Baştan global modellersen sonradan refactor yok."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) fullName tek alan + opsiyonel given/family. 2) E.164 + libphonenumber. 3) "
       },
       {
        "type": "term",
        "text": "i18n-postal-address",
        "termId": "term-i18n-postal-address-cc-identity-models"
       },
       {
        "type": "text",
        "text": ". 4) VAT VIES API. 5) Cinsiyet opsiyonel + non-binary. 6) "
       },
       {
        "type": "term",
        "text": "Veri minimizasyonu",
        "termId": "term-veri-minimizasyonu-cc-identity-models"
       },
       {
        "type": "text",
        "text": " (yaş aralığı)."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "cc-identity-models"
       },
       {
        "type": "text",
        "text": " cluster + "
       },
       {
        "type": "code",
        "text": "l1-party"
       },
       {
        "type": "text",
        "text": " ArcheType ile entegre."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk kullanıcı kaydından ÖNCE. Sonradan migration ağrılı."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Backend dev şema; frontend dev ülke-aware form; hukuk team yasal cinsiyet/yaş kuralları."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Pasaport ofisi: her ülkenin pasaport formatı farklı (TR çipli, AB elektronik, Hindistan basılı), ama dünya genelinde 'pasaport' kavramı standart. ICAO yapısı tek; içerik ülke-aware. Kimlik veri modeli aynı: ortak iskelet + ülke-aware özelleştirme."
       }
      ]
     }
    ]
   },
