   {
    "id": "block-cc-identity-models-code",
    "type": "codeBlock",
    "language": "sql",
    "code": "CREATE TABLE person (\n  id BIGSERIAL,\n  full_name TEXT NOT NULL,                -- ham, kullanıcının yazdığı\n  display_name TEXT,                      -- kısa (UI'de gösterim)\n  given_name TEXT,                        -- opsiyonel (Latin alfabeli kültürler için)\n  family_name TEXT,                       -- opsiyonel\n  name_order ENUM('given_family','family_given','single','custom') DEFAULT 'given_family',\n  honorific_prefix TEXT,                  -- 'Dr.', 'Prof.', 'H.E.'\n  honorific_suffix TEXT,                  -- 'Jr.', 'PhD'\n  preferred_pronouns TEXT,                -- opsiyonel ('he/him', 'she/her', 'they/them')\n  ...\n);"
   },
   {
    "id": "block-cc-identity-models-p-6",
