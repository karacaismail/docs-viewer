    "id": "block-edu-u03-doctype-code",
    "type": "codeBlock",
    "title": "archetype/musteri_sikayeti.yml",
    "language": "yaml",
    "code": "archetype: MusteriSikayeti\nnaming: format:SIK-{YYYY}-{####}\nis_submittable: false\nfields:\n  - name: konu          # Field name (DB kolon adı)\n    type: Data          # max 140 char string\n    required: true\n    in_list_view: true  # liste sayfasında görünsün\n\n  - name: aciklama\n    type: Text          # uzun metin\n    required: true\n\n  - name: oncelik\n    type: Select        # closed enum\n    options: [\"dusuk\", \"orta\", \"yuksek\", \"acil\"]\n    default: \"orta\"\n\n  - name: atanan\n    type: Link          # başka ArcheType'a FK\n    options: User       # hangi ArcheType — User\n\n  - name: musteri\n    type: Link\n    options: Customer\n    required: true\n    in_list_view: true\n\n  - name: ekler\n    type: Table         # child table (1-N)\n    options: SikayetEki # child ArcheType\n\npermissions:\n  - role: Manager\n    perm: [read, write, create, delete]\n  - role: Customer\n    perm: [read, create]\n    ifowner: true       # sadece kendi kayıtlarını görsün\n\nhooks:\n  on_change: helpdesk.handlers.on_complaint_change"
   },
