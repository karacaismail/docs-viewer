    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "DocType ≠ tek tablo + type switching. Klasik DDD'nin 3 yaklaşımı (ayrı "
       },
       {
        "type": "term",
        "text": "aggregate",
        "termId": "term-aggregate-edu-u25-doctype-vs-ddd"
       },
       {
        "type": "text",
        "text": " / Strategy / value object) runtime metadata olarak yaşar."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Tek tablo + if-else = anemic domain anti-pattern. Yeni tip eklemek mevcut kodu kırar. DocType doğru kurulursa: Strategy + tablo-per-tip + policy plugin."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) DocType admin paneli (k-schema). 2) Her DocType kendi DB tablosu (DDL generation). 3) Kuralı varsa policy plugin (Strategy). 4) Sadece etiketse value object enum."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "k-schema"
       },
       {
        "type": "text",
        "text": " cluster — engine. "
       },
       {
        "type": "code",
        "text": "s-studio"
       },
       {
        "type": "text",
        "text": " — low-code arayüz. Bu cluster — pedagoji."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk DocType tanımından ÖNCE bu disiplin net olmalı."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Mimar DocType pattern karar; geliştirici policy plugin yazımı; admin user runtime'da yeni tip tanımı."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Kitapçı: 1 defter + 'bu satır fatura' notu = karmaşa (anemic). Ayrı defterler = klasik DDD. Bilgisayardan 'yeni defter türü tanımla' = meta-framework. Üçü de farklı yaklaşım; en kötü 1. Bu proje 3."
       }
      ]
     }
    ]
