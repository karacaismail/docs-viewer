   {
    "id": "block-edu-u14-cache-ratelimit-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Cache: aynı işi 2 kez yapmamak için hızlı hafızada sakla. Rate limit: bir kullanıcının kapasiteyi tek başına tüketmesini engelle."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Cache olmadan sistem 1000 eşzamanlı kullanıcıya dayanamaz. Rate limit olmadan bir kötü niyetli kullanıcı sistemi yıkar."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) Sık okunan, az değişen veriyi Redis'e cache'le. TTL: 60sn-1 saat arası. 2) Değişince invalidate et. 3) Her API endpoint'inde rate limit middleware. 4) Token bucket: kullanıcı/IP başına saniyede 10 token, max 100 burst."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Cache: "
       },
       {
        "type": "code",
        "text": "scale-cache"
       },
       {
        "type": "text",
        "text": " cluster. Rate limit: "
       },
       {
        "type": "code",
        "text": "scale-ratelimit"
       },
       {
        "type": "text",
        "text": " cluster. Her ikisi de Layer-1 öncesi middleware'da çalışır."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Cache: aynı sorguya günde 100+ istek varsa. Rate limit: public endpoint her zaman; internal API en az."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "SRE/mimar TTL kuralını koyar; geliştirici cache key'i seçer; pazarlama quota tier'ı belirler."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Cache = sık çıkardığın eşyayı dolaba değil masaya koyma. Rate limit = sınıfta 'her öğrenci 5 dk söz hakkı' kuralı."
       }
      ]
     }
    ]
   },
