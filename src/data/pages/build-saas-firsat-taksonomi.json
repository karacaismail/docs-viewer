    "type": "callout",
    "variant": "info",
    "title": "Sınıflandırma kuralı",
    "segments": [
     {
      "type": "text",
      "text": "Stack = yatay/genel ürün motoru (CRM, FSM, HRMS, BI…). Edition = bir Stack'in dikey UX/GTM paketi ('Dikey X', departman copilot). Distribution = Edition + config + sektör içeriği (adıyla bir sektör dikeyi: klinik, otel, restoran, ilan/pazaryeri… veya entegre suite: ERP, B2B portal)."
     }
    ]
