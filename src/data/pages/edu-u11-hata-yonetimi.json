   },
   {
    "id": "block-edu-u11-hata-yonetimi-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Bir kod parçasının hatasını yakalamak, gerekirse tekrar denemek, deneme başarısız olursa park alanına atmak. Üç katman var: validation (önle), retry (geçici sorun), DLQ (kalıcı sorun)."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Hata olmadan yazılım üretime çıkamaz. Doğru hata yönetimi olmadan üretim her gece sahibini uyandırır."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) try/catch yalnız beklenmedik hata için — kullanıcı hatası validation'da yakalansın. 2) Geçici hata için retry + backoff. 3) Hala başarısızsa DLQ. 4) DLQ'ya düşeni mutlaka insan görsün — alarm bağla."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Her dış sistem çağrısında (banka, email, SMS, kargo API, vb.) — outbound webhook + scale-saga + DLQ var."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Üretimde "
       },
       {
        "type": "strong",
        "text": "her"
       },
       {
        "type": "text",
        "text": " dış çağrı için. İçeride bile veritabanı kilitlenebilir → retry'a sahip ol."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Geliştirici try/catch yazar; SRE retry kuralını ayarlar; on-call mühendis DLQ'yu inceler."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Trafik ışığında araç bekleyiş = retry (geçici engel). Çıkmaz sokak = DLQ (vazgeç, geri dön). Sürekli çalan ev zili = "
       },
       {
        "type": "term",
        "text": "circuit breaker",
        "termId": "term-circuit-breaker-edu-u11-hata-yonetimi"
       },
       {
        "type": "text",
        "text": " (kimse açmıyorsa bir süre çalma)."
       }
      ]
     }
    ]
