    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Sistem, AI'nın eyleyebileceği işlemleri tipli, kimliği doğrulanmış, sandbox'lı \"action\" olarak ilan eder: "
       },
       {
        "type": "code",
        "text": "publish_order(...)"
       },
       {
        "type": "text",
        "text": ", "
       },
       {
        "type": "code",
        "text": "approve_invoice(...)"
       },
       {
        "type": "text",
        "text": ". AI ham veritabanına dokunmaz; sadece bu eylemleri çağırır."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "AI'ya \"hadi serbest çalış\" demek kaza demektir. AI tipli eyleme erişirse: kuralları sistem zorlatır, audit otomatik tutulur, izinsiz girişim engellenir. Güvenlik + denetlenebilirlik içkin."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "Her action JSON-Schema imzalı (giriş ve çıkış tipleri belli), authz politikasıyla bağlı, side-effect'leri kayıt altında. AI ajan MCP (Model Context Protocol) üzerinden bu action'lara erişir."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "framework/kernel/actions/ — her action ayrı dosya, manifest'te listeli."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk AI ajanı sisteme bağlanmadan önce — sonra eklemek geç olur (güvenlik açığı)."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Mimar action'ları tasarlar; geliştirici implement eder; AI ajan MCP üzerinden çağırır; denetçi audit'i okur."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Bir restoranda garsona \"mutfağa gir, istediğini al\" demezsin. Garson sadece menüden sipariş alır; mutfak siparişe göre yemek hazırlar. Menü = action yüzeyi; mutfak = veri katmanı. AI = garson."
       }
      ]
     }
    ]
   },
