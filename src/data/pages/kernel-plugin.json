    "language": "yaml",
    "code": "name: my_inventory_extension\nversion: 1.2.3\napi_version: \"1.0\"        # framework API contract version\npublisher: acme-corp\nlicense: LGPL-3.0\ndescription: \"Custom inventory extensions for Acme\"\n\ndepends:\n  - framework: \"^1.0.0\"\n  - commerce: \"^2.1.0\"\n  - accounting: \"^1.5.0\"\n\npermissions:\n  - read: [Customer, SalesOrder]\n  - write: [SalesOrder]\n  - publish_event: [OrderShipped]\n\nhooks:\n  doc_events:\n    SalesOrder:\n      before_save: handlers/sales_order.py::before_save\n      on_submit: handlers/sales_order.ts::onSubmit\n  schedule:\n    daily: tasks/cleanup.py::daily_cleanup\n    cron:\n      - schedule: \"0 */6 * * *\"\n        handler: tasks/sync.py::sync_partners\n\narchetypes:           # ArcheType'ları bu modül tanımlar\n  - definitions/custom_field.json\n\nfixtures:           # Initial data (seed)\n  - fixtures/categories.json\n\ntranslations:\n  - translations/tr.po\n  - translations/en.po\n\nui:\n  pages:\n    - path: /inventory/dashboard\n      component: pages/Dashboard.tsx\n  menu:\n    - title: \"Acme Inventory\"\n      icon: ph-package\n      route: /inventory"
