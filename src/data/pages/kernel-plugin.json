   {
    "id": "block-kernel-plugin-h-yedi-soruda",
    "type": "heading",
    "level": 2,
    "text": "Bu konu yedi soruda"
   },
   {
    "id": "block-kernel-plugin-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Sistemin ana koduna dokunmadan yeni özellikler eklemenizi sağlayan eklenti listesi. Telefonun uygulama mağazasına benzer."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Her müşterinin ihtiyacı farklı. Birine 'kargo entegrasyonu', diğerine 'e-fatura' lazım. Eklenti olmasaydı her müşteriye ayrı sistem yazardık."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "Eklenti yazarı bir 'tanıtım kartı' (manifest) hazırlar. Sistem bu kartı okur, eklentiyi listesine ekler. Kullanıcı 'kur' butonuna bastığında eklenti devreye girer."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "text",
        "text": "Yönetici panelinde 'Eklentiler' menüsü. Açıp kapatabilir, ayarlarını değiştirebilirsiniz."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "Yeni bir iş ihtiyacı doğduğunda. Sistem yazarına bağımlı kalmadan, hazır eklentilerden seçersiniz."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Üçüncü taraf yazarlar yazar; sistem yöneticisi kurar; son kullanıcı yeni özelliği menüde görür."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Mutfak robotunun aksesuarları: aynı motor, farklı uçlar. Bugün doğrayıcı taktınız, yarın blender. Robot değişmez; iş değişir."
       }
      ]
     }
    ]
   },
