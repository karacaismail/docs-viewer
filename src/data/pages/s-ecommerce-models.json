    "id": "block-s-ecommerce-models-code",
    "type": "codeBlock",
    "language": "sql",
    "code": "CREATE TABLE tenant_capabilities (\n  tenant_id INT,\n  capability TEXT,        -- 'b2c', 'b2b', 'marketplace', 'dropship', 'subscription'\n  enabled BOOL DEFAULT false,\n  enabled_at TIMESTAMPTZ,\n  PRIMARY KEY (tenant_id, capability)\n);"
   },
