   {
    "id": "block-s-ecommerce-models-h-yedi-soruda",
    "type": "heading",
    "level": 2,
    "text": "Bu konu yedi soruda"
   },
   {
    "id": "block-s-ecommerce-models-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "E-ticaret iş modelleri (B2C, B2B, marketplace vs.) ayrı yazılımlar değil — tek altyapıda capability flag olarak açılan yetenekler."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Müşteri büyürken model değişir (B2C → +B2B → +marketplace). Geleneksel yaklaşım yeni yazılım kurar veya migration yapar; ikisi de pahalı + risk. Capability flag = sıfır migration, sıfır risk."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) Sell-side ve Buy-side aktör tipini DocType'ta tut. 2) Capability flag tablosu tenant başına. 3) UI feature flag ile koşullu görünüm. 4) Model adı (B2B, B2C vs.) view layer'da derived/hesaplanan alan."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "s-ecommerce-models"
       },
       {
        "type": "text",
        "text": " cluster — felsefe + matris. "
       },
       {
        "type": "code",
        "text": "s-commerce"
       },
       {
        "type": "text",
        "text": " cluster — uygulama. "
       },
       {
        "type": "code",
        "text": "k-tenancy"
       },
       {
        "type": "text",
        "text": " — capability tablosu."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk e-ticaret tenant'ı oluşturulmadan ÖNCE bu mimari karar. Sonradan refactor 1000x pahalı."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Mimar capability listesi tanımlar; backend developer flag tabloyu kurar; ürün ekibi hangi yetenek hangi tier'da satılır karar."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Apartman dairesi: 1+1 olarak başlar, sahibi balkon kapatır (yetenek+), bodrumu mağaza yapar (yetenek+), sonra çatıya teras (yetenek+). Daire tipini değiştirmedi; "
       },
       {
        "type": "strong",
        "text": "yetenekler ekledi"
       },
       {
        "type": "text",
        "text": ". Her ekleme öncekini yıkmadan yapıldı."
       }
      ]
     }
    ]
   },
