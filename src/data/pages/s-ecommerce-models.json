    "id": "block-s-ecommerce-models-story-3",
    "type": "useCase",
    "title": "Yusuf Bey (66) — kamu ihalesi (B2G)",
    "scenario": [
     {
      "type": "text",
      "text": "Yusuf Bey emekli, küçük temizlik ürünleri toptanı işletiyor. Belediyenin temizlik malzeme ihalesini aldı. Normal satış sisteminde fatura kesmek farklı — B2G fatura formatı, e-İhale entegrasyonu, ödeme 60 gün vadeli."
     }
    ],
    "outcome": [
     {
      "type": "strong",
      "text": "b2g capability"
     },
     {
      "type": "text",
      "text": " açılır → aynı sistemden B2G siparişi: fatura otomatik kamu formatında, ödeme termini 60 gün varsayılan, e-İhale ID kaydedilir. Mevcut B2C siparişleri etkilenmez."
     }
