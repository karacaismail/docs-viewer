    "id": "block-s-ecommerce-models-story",
    "type": "useCase",
    "title": "Bakkal Hatice Teyze (62) — online satış başlangıcı",
    "scenario": [
     {
      "type": "text",
      "text": "Hatice Teyze mahallede 30 yıllık bakkal. Pandemide WhatsApp'tan sipariş aldı. Şimdi gerçek bir online satış kurmak istiyor: önce mahalleye paket servisi (B2C), sonra civar marketlere toptan satış (B2B), bir gün belki başka bakkalları da pazaryerine alacak (marketplace)."
     }
    ],
    "outcome": [
     {
      "type": "text",
      "text": "Bu sistemde tek bir hesap. Önce "
     },
     {
      "type": "strong",
      "text": "b2c capability"
     },
     {
      "type": "text",
      "text": " açılır — site, sepet, ödeme. 6 ay sonra "
     },
     {
      "type": "strong",
      "text": "b2b capability"
     },
     {
      "type": "text",
      "text": " açılır — toptan müşteri kartı + vergi no + kredi limiti aynı sistemde. Bir sonraki sene "
     },
     {
      "type": "strong",
      "text": "marketplace capability"
     },
     {
      "type": "text",
      "text": " — başka satıcılar Hatice Teyze'nin sitesinde mağaza açar, komisyon alır. "
     },
     {
      "type": "strong",
      "text": "Tek migration yok, hep eklemeli."
     }
    ]
