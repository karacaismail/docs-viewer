   {
    "id": "block-cc-jurisdiction-resolver-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Kıtalararası SaaS için 6 bağımsız ekseni (locale, jurisdiction, currency, tax, timezone, data-residency) çözen ve yürürlükteki kural setini hesaplayan policy resolver servisi."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Tek-locale yaklaşımı 'codebase her ülkede farklı' demek; doğru mimari 'config her ülkede farklı, kod aynı'. Amazon/eBay'in görünmez sihri."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) 6 eksen ayrı resolve. 2) Versiyonlu policy_json config tablosu. 3) decision_trace audit. 4) Çatışma matrisi (precedence). 5) Cache + deny-by-default fallback. 6) 4-göz config onayı."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "cc-jurisdiction-resolver"
       },
       {
        "type": "text",
        "text": " cluster + Layer-1 öncesi middleware. Her request bu resolver'dan geçer."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk ikinci-ülke kullanıcısından ÖNCE. Sonradan refactor 1000x pahalı. Pre-revenue startup için bile baştan."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Mimar 6 eksen tasarım; backend dev resolver implementasyonu; hukuk ekibi kural yazımı; SRE config dağıtımı."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Apartman site yönetimi: kapı (giriş kontrolü), su (currency), elektrik (tax), gaz (timezone), internet (data residency), site sözleşmesi (locale). Her biri ayrı altyapı; biri kesilirse diğeri çalışır. 'Her şey tek hat' demek = tek arıza her şeyi durdurur."
       }
      ]
     }
    ]
   },
