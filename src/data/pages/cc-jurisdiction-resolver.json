    "id": "block-cc-jurisdiction-resolver-p-10",
    "type": "paragraph",
    "segments": [
     {
      "type": "strong",
      "text": "Config-as-data (versiyonlu policy store):"
     }
    ]
   },
   {
    "id": "block-cc-jurisdiction-resolver-code-2",
    "type": "codeBlock",
    "language": "sql",
    "code": "CREATE TABLE jurisdiction_policy (\n  policy_id BIGSERIAL,\n  jurisdiction_code TEXT,         -- 'TR', 'EU', 'DE', 'US-CA'\n  version INT,                    -- versiyonlu, geri dönülebilir\n  effective_from TIMESTAMPTZ,\n  effective_to TIMESTAMPTZ,\n  policy_json JSONB,              -- consent_age, tax_inclusive, currency, retention_years, ...\n  created_by INT,\n  approved_by INT,                -- 4-göz onayı\n  PRIMARY KEY (policy_id)\n);\n\nCREATE TABLE decision_trace (\n  request_id UUID,\n  user_id INT,\n  resolved_locale TEXT,\n  resolved_jurisdiction TEXT,\n  resolved_currency CHAR(3),\n  resolved_tax_region TEXT,\n  resolved_timezone TEXT,\n  resolved_data_residency TEXT,\n  applied_policy_id BIGINT,       -- hangi versiyonlu kural seti uygulandı\n  decided_at TIMESTAMPTZ DEFAULT now()\n);"
   },
   {
    "id": "block-cc-jurisdiction-resolver-p-11",
    "type": "paragraph",
    "segments": [
     {
      "type": "strong",
      "text": "Operasyonel sertleştirme:"
     }
    ]
   },
   {
    "id": "block-cc-jurisdiction-resolver-list",
    "type": "list",
    "ordered": false,
    "items": [
     [
      {
       "type": "strong",
       "text": "Cache"
      },
      {
       "type": "text",
       "text": ": resolver hot path. Per-user → kısa TTL (5 dk). Per-jurisdiction config → uzun TTL + event-based invalidation (config değişti → cache flush)."
      }
     ],
     [
      {
       "type": "strong",
       "text": "Failure mode"
      },
      {
       "type": "text",
       "text": ": resolver veya config eksikse → "
      },
      {
       "type": "strong",
       "text": "deny-by-default"
      },
      {
       "type": "text",
       "text": " (en sıkı kural uygulanır). Sessiz kabul YASAK."
      }
     ],
     [
      {
       "type": "strong",
       "text": "Audit"
      },
      {
       "type": "text",
       "text": ": her decision'ı decision_trace'a yaz. 'Neden bu kullanıcıya EUR + DE KDV uygulandı' sorusunun cevabı."
      }
     ],
     [
      {
       "type": "strong",
       "text": "Config yetkisi"
      },
      {
       "type": "text",
       "text": ": OpenFGA ile config-write yetkisi 4-göz onayına bağlı. Yanlış config = yasal ihlal."
      }
     ]
    ]
   },
   {
    "id": "block-cc-jurisdiction-resolver-h-yedi-soruda",
    "type": "heading",
    "level": 2,
    "text": "Bu konu yedi soruda"
