   {
    "id": "block-cc-content-jurisdiction-lesson",
    "type": "definitionList",
    "items": [
     {
      "term": "Ne?",
      "definition": [
       {
        "type": "text",
        "text": "Ülke bazlı içerik kısıtları (sansür, yaş, birim, voltaj), AB e-fatura formatları, takvim sistemleri, geo-blocking, lawful intercept akışı."
       }
      ]
     },
     {
      "term": "Niçin?",
      "definition": [
       {
        "type": "text",
        "text": "Resolver locale + jurisdiction çözer ama 'ne göstereceği' başka katman. Bu cluster içerik/ürün-tarafı kuralları."
       }
      ]
     },
     {
      "term": "Nasıl?",
      "definition": [
       {
        "type": "text",
        "text": "1) content_filter_rules per jurisdiction (config-as-data). 2) age_gate capability. 3) Birim canonical + display dönüştürücü (UCUM). 4) e_invoice_adapter per AB ülkesi. 5) business_calendar tatil tablosu. 6) lawful_intercept_workflow."
       }
      ]
     },
     {
      "term": "Nerede?",
      "definition": [
       {
        "type": "code",
        "text": "cc-content-jurisdiction"
       },
       {
        "type": "text",
        "text": " cluster + "
       },
       {
        "type": "code",
        "text": "cc-jurisdiction-resolver"
       },
       {
        "type": "text",
        "text": " (jurisdiction çözer) + "
       },
       {
        "type": "code",
        "text": "cc-compliance-matrix"
       },
       {
        "type": "text",
        "text": " (sanctions, KVKK)."
       }
      ]
     },
     {
      "term": "Ne zaman?",
      "definition": [
       {
        "type": "text",
        "text": "İlk ek ülke açılımından ÖNCE. AB açıldıysan e-fatura, DE açıldıysan content filter zorunlu."
       }
      ]
     },
     {
      "term": "Kim?",
      "definition": [
       {
        "type": "text",
        "text": "Hukuk team kural yazımı; ürün ekibi katalog filtre; backend dev adapter; legal counsel lawful intercept."
       }
      ]
     },
     {
      "term": "Analoji",
      "definition": [
       {
        "type": "text",
        "text": "Gümrük: ülkeye giriş yaparken kabul edilmeyen şeyler var (alkol Suudi, et Türkiye gibi bazı yerler), birim farklı (gallon vs litre), ödeme farklı (Suudi Riyal vs Euro). Sistem kuralları gümrük gibi: ülkeye göre değişir."
       }
      ]
     }
    ]
