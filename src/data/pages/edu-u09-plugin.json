    "title": "Filter vs Action — pratik örnek",
    "segments": [
     {
      "type": "strong",
      "text": "Filter"
     },
     {
      "type": "text",
      "text": ": "
     },
     {
      "type": "code",
      "text": "apply_filter('order_total', $total)"
     },
     {
      "type": "text",
      "text": " → her plugin total'ı modifiye edebilir (kupon plugin %10 düşer). "
     },
     {
      "type": "strong",
      "text": "Action"
     },
     {
      "type": "text",
      "text": ": "
     },
     {
      "type": "code",
      "text": "do_action('order_placed', $order)"
     },
     {
      "type": "text",
      "text": " → her plugin tepki verir (email plugin gönderir, analytics plugin loglar). İkisi de hook ama farklı semantik."
     }
