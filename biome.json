{
 "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
 "files": {
  "includes": ["src/**", "tests/**", "e2e/**", "tools/**", "*.json", "*.ts", "!src/data", "!content-source"]
 },
 "formatter": {
  "enabled": true,
  "indentStyle": "space",
  "indentWidth": 2,
  "lineWidth": 110
 },
 "linter": {
  "enabled": true,
  "rules": {
   "recommended": true,
   "style": {
    "noNonNullAssertion": "off"
   },
   "suspicious": {
    "noConsole": "off",
    "noArrayIndexKey": "off"
   }
  }
 },
 "javascript": {
  "formatter": {
   "quoteStyle": "double",
   "semicolons": "always"
  }
 },
 "json": {
  "formatter": {
   "indentWidth": 1
  }
 }
}
