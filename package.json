{
  "name": "docs-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "migrate": "node tools/migrate/index.mjs",
    "build": "npm run migrate && tsc --noEmit && VITE_OUT=/tmp/docs-viewer-build vite build && node tools/syncBuild.mjs",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
    "size": "size-limit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.5",
    "@fontsource/roboto-mono": "^5.2.5",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-router": "^1.114.0",
    "clsx": "^2.1.1",
    "minisearch": "^7.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^3.2.1",
    "zod": "^3.24.2"
  },
  "size-limit": [
    {
      "name": "initial JS — 14 #15 bütçesi (eager chunk'lar: app + vendor + content-meta)",
      "path": [
        "build/assets/index-*.js",
        "build/assets/vendor-*.js",
        "build/assets/content-meta-*.js"
      ],
      "limit": "250 KB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@size-limit/file": "^11.2.0",
    "size-limit": "^11.2.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.2.0",
    "@vitest/coverage-v8": "^3.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
