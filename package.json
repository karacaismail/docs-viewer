{
  "name": "docs-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "migrate": "node tools/migrate/index.mjs",
    "build": "npm run migrate && tsc --noEmit && VITE_OUT=/tmp/docs-viewer-build vite build && node tools/syncBuild.mjs",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.5",
    "@fontsource/roboto-mono": "^5.2.5",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-router": "^1.114.0",
    "clsx": "^2.1.1",
    "minisearch": "^7.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^3.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
